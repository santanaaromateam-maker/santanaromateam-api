# =============================================================================
# Santana Aroma — Backend (FastAPI)
# Copy to .env and fill in your values
# =============================================================================

# ── App / JWT ──
SECRET_KEY=change-this-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── MongoDB ──
# Cadena COMPLETA de conexión (usuario y contraseña incluidos).
# Atlas → Connect → Drivers → copia el connection string y reemplaza <password>.
# Ejemplo:
#   mongodb+srv://miuser:miclave@cluster0.xxxxx.mongodb.net/santana_aroma?retryWrites=true&w=majority
# Si la contraseña tiene caracteres especiales (@, #, :, /), codifícala en URL (ej. @ → %40).
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=santana_aroma

# ── Admin user (created on first startup if it does not exist) ──
ADMIN_EMAIL=admin@santanaaromateam.com
ADMIN_PASSWORD=change-me

# ── Cloudinary (image uploads) ──
# https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=santana-aroma/services

# ── CORS — allowed browser origins ──
# Must match EXACTLY the URL in the browser (scheme + host, no trailing slash).
# Admin panel — local + production Render URL:
ADMIN_ORIGIN=http://localhost:5173,https://santanaromateam-admin.onrender.com

# Public website:
WEB_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8001,http://127.0.0.1:8001,https://santanaaromateam.com,https://www.santanaaromateam.com

# Optional: extra origins if the admin has another URL (comma-separated)
# CORS_ORIGINS=
